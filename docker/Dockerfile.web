FROM node:20-slim AS css-builder
WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY src/web/static/css/input.css src/web/static/css/input.css
COPY src/web/templates/ src/web/templates/
RUN npm run css:build

FROM python:3.10-slim
WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

RUN apt-get update && \
    apt-get install -y --no-install-recommends gcc git \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY src/ ./src/
COPY --from=css-builder /app/src/web/static/css/output.css src/web/static/css/output.css

RUN useradd -m -u 1000 webuser && \
    chown -R webuser:webuser /app

USER webuser

EXPOSE 8080

CMD ["python", "-m", "src.web.app"]
