# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_application_client_id_here

# ── Etsy API credentials (from developer.etsy.com) ───────────────────────────
ETSY_API_KEY=your_keystring_here
ETSY_SHARED_SECRET=your_shared_secret_here

# ── Web server ────────────────────────────────────────────────────────────────
# Public URL where the web server is reachable (no trailing slash)
WEB_BASE_URL=https://shopkeep.example.com
# Redirect URI registered in your Etsy app for the web OAuth flow
ETSY_WEB_REDIRECT_URI=https://shopkeep.example.com/callback/etsy

# ── Bot settings ──────────────────────────────────────────────────────────────
POLL_INTERVAL_SECS=60
DB_PATH=/app/data/shopkeep.db

# ── Single-tenant dev (optional, for scripts/etsy_auth.py) ───────────────────
# ETSY_REDIRECT_URI=http://localhost:3000/callback
# ETSY_ACCESS_TOKEN=your_access_token_here
# ETSY_REFRESH_TOKEN=your_refresh_token_here
